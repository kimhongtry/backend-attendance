{
  "compilerOptions": {
    /* Target & Module */
    "target": "ES2021",
    "module": "CommonJS",
    "lib": ["ES2021"],
    "rootDir": "./src",
    "outDir": "./dist",

    /* Module Resolution */
    "moduleResolution": "node",
    "baseUrl": "./",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    /* TypeORM Specifics (Experimental) */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,

    /* Strictness & Safety */
    "strict": true,
    "strictPropertyInitialization": false, // Required for @Column()
    
    /* Paths */
    "paths": {
      "*": ["node_modules/*", "src/types/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "**/*.spec.ts", "dist"]
}